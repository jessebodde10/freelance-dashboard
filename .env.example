# Supabase — copy to .env and fill with your project's values.
# Find these in the Supabase dashboard: Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional — only if your "send-quote" edge function has a different URL slug
# (the dashboard sometimes auto-generates one like "hyper-task"). Set it to the
# slug shown in the function's URL: .../functions/v1/<slug>. Defaults to send-quote.
# VITE_SEND_QUOTE_FN=send-quote
