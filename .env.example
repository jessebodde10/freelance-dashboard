# Supabase — copy to .env and fill with your project's values.
# Find these in the Supabase dashboard: Project Settings → API.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional — only if your "send-quote"/"send-invoice"/"send-contact" edge
# functions have a different URL slug (the dashboard sometimes auto-generates
# one like "hyper-task"). Set each to the slug shown in the function's URL:
# .../functions/v1/<slug>. Default to send-quote / send-invoice / send-contact.
# VITE_SEND_QUOTE_FN=send-quote
# VITE_SEND_INVOICE_FN=send-invoice
# VITE_SEND_CONTACT_FN=send-contact
